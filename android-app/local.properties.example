# Copy to local.properties (gitignored).
sdk.dir=/Users/yourname/Library/Android/sdk

# Optional — Flask bridge base URL (default in build.gradle is http://127.0.0.1:8765/)
# Trailing slash is normalized at build time for Retrofit.
#
# Android emulator → Flask on host:
# PITWALL_API_BASE_URL=http://10.0.2.2:8765/
#
# Physical Pixel + Termux bridge on-device:
# PITWALL_API_BASE_URL=http://127.0.0.1:8765/
